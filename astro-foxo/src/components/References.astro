---
import type { ReferencesBlockData } from '../lib/types';

interface Props {
  data: ReferencesBlockData;
}

const { data } = Astro.props;
---

<section id="references" class="py-20 md:py-28 relative overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[#f7941e]/10 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-6 text-white">
        {data.ref_heading} <span class="text-[#f7941e]">{data.ref_heading_highlight}</span>
      </h2>
      {data.ref_description && (
        <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
          {data.ref_description}
        </p>
      )}
    </div>

    {data.ref_clients && data.ref_clients.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {data.ref_clients.map((client) => (
          <div class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-2xl p-8 hover:bg-white/10 hover:border-[#f7941e]/50 transition-all hover:shadow-xl hover:shadow-[#f7941e]/20 flex flex-col items-center text-center">
            {client.icon && (
              <div class="w-full h-16 mb-6 flex items-center justify-center">
                <img src={client.icon.url} alt={client.icon.alt} width="48" height="48" class="w-full h-12 object-contain" />
              </div>
            )}
            <h3 class="text-xl font-bold mb-4 text-white">{client.name}</h3>
            <p class="text-gray-400 leading-relaxed text-sm">{client.description}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
