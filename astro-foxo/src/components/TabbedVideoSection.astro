---
---

<div class="relative w-full h-[500px] md:h-[600px] flex items-center justify-center overflow-hidden">
  <!-- Floating Shape 1 - Large Circle -->
  <div class="floating-shape-1 absolute w-64 h-64 rounded-full bg-gradient-to-br from-[#f7941e]/20 to-transparent border border-white/10 backdrop-blur-xl" style="box-shadow: 0 0 60px rgba(247, 148, 30, 0.3)"></div>

  <!-- Floating Shape 2 - Rectangle -->
  <div class="floating-shape-2 absolute w-48 h-72 rounded-3xl bg-gradient-to-tr from-gray-800/40 via-gray-900/30 to-black/40 border border-white/20"></div>

  <!-- Floating Shape 3 - Small Orange Circle -->
  <div class="floating-shape-3 absolute w-32 h-32 rounded-full bg-[#f7941e]/30 border border-[#f7941e]/50 backdrop-blur-lg" style="box-shadow: 0 0 80px rgba(247, 148, 30, 0.5)"></div>

  <!-- Floating Shape 4 - Elongated Capsule -->
  <div class="floating-shape-4 absolute w-40 h-20 rounded-full bg-gradient-to-r from-white/5 to-white/10 border border-white/20 backdrop-blur-md"></div>

  <!-- Floating Shape 5 - Square with Rounded Corners -->
  <div class="floating-shape-5 absolute w-44 h-44 rounded-2xl bg-gradient-to-bl from-gray-700/30 to-black/50 border border-white/10 backdrop-blur-xl"></div>

  <!-- Central Pulsing Ring -->
  <div class="pulsing-ring-1 absolute w-80 h-80 rounded-full border-2 border-[#f7941e]/40"></div>

  <!-- Secondary Pulsing Ring -->
  <div class="pulsing-ring-2 absolute w-96 h-96 rounded-full border border-white/20"></div>

  <!-- Decorative Orange Glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[#f7941e]/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
</div>

<style>
  @keyframes float-shape-1 {
    0% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(100px, -80px) rotate(90deg) scale(1.2); }
    50% { transform: translate(0, -160px) rotate(180deg) scale(1); }
    75% { transform: translate(-100px, -80px) rotate(270deg) scale(0.8); }
    100% { transform: translate(0, 0) rotate(360deg) scale(1); }
  }

  @keyframes float-shape-2 {
    0% { transform: translate(-120px, 60px) rotate(0deg); }
    50% { transform: translate(120px, -60px) rotate(-180deg); }
    100% { transform: translate(-120px, 60px) rotate(-360deg); }
  }

  @keyframes float-shape-3 {
    0% { transform: translate(100px, -100px) scale(1); }
    50% { transform: translate(-100px, 100px) scale(1.5); }
    100% { transform: translate(100px, -100px) scale(1); }
  }

  @keyframes float-shape-4 {
    0% { transform: translate(-80px, 120px) rotate(45deg); }
    50% { transform: translate(80px, -40px) rotate(225deg); }
    100% { transform: translate(-80px, 120px) rotate(405deg); }
  }

  @keyframes float-shape-5 {
    0% { transform: translate(60px, -80px) rotate(0deg) scale(1); }
    50% { transform: translate(-60px, 80px) rotate(180deg) scale(0.7); }
    100% { transform: translate(60px, -80px) rotate(360deg) scale(1); }
  }

  @keyframes pulse-ring-1 {
    0% { transform: scale(1) rotate(0deg); opacity: 0.4; }
    50% { transform: scale(1.3) rotate(180deg); opacity: 0.8; }
    100% { transform: scale(1) rotate(360deg); opacity: 0.4; }
  }

  @keyframes pulse-ring-2 {
    0% { transform: scale(1.2) rotate(360deg); opacity: 0.2; }
    50% { transform: scale(1) rotate(180deg); opacity: 0.5; }
    100% { transform: scale(1.2) rotate(0deg); opacity: 0.2; }
  }

  .floating-shape-1 {
    animation: float-shape-1 20s ease-in-out infinite;
  }

  .floating-shape-2 {
    animation: float-shape-2 25s ease-in-out infinite;
  }

  .floating-shape-3 {
    animation: float-shape-3 15s ease-in-out infinite;
  }

  .floating-shape-4 {
    animation: float-shape-4 18s ease-in-out infinite;
  }

  .floating-shape-5 {
    animation: float-shape-5 22s ease-in-out infinite;
  }

  .pulsing-ring-1 {
    animation: pulse-ring-1 12s ease-in-out infinite;
  }

  .pulsing-ring-2 {
    animation: pulse-ring-2 15s ease-in-out infinite;
  }
</style>
