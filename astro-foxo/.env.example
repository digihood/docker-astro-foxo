# WordPress REST API URL (Docker: http://localhost:8080)
WP_API_URL=http://localhost:8080

# Revalidation secret (must match FOXO_REVALIDATE_SECRET in wp-config.php)
REVALIDATE_SECRET=dev-revalidate-secret

# Preview secret (must match FOXO_PREVIEW_SECRET in wp-config.php)
PREVIEW_SECRET=dev-preview-secret

# Public frontend URL (used for ISR revalidation + sitemap proxy)
PUBLIC_SITE_URL=http://localhost:4321
