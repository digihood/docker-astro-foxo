---
import type { ServicesBlockData } from '../lib/types';

interface Props {
  data: ServicesBlockData;
}

const { data } = Astro.props;
---

<section id="services" class="py-20 md:py-28 relative ">
  <!-- Background glow -->
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#f7941e]/10 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-6 text-white">
        {data.services_heading} <span class="text-[#f7941e]">{data.services_heading_highlight}</span>
      </h2>
      {data.services_description && (
        <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
          {data.services_description}
        </p>
      )}
    </div>

    {data.services_items && data.services_items.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {data.services_items.map((service) => (
          <div class="bg-white/5 backdrop-blur-lg border border-white/10 hover:border-[#f7941e]/50 rounded-2xl p-8 transition-all hover:bg-white/10 hover:shadow-xl hover:shadow-[#f7941e]/20">
            {service.icon && (
              <div class="w-16 h-16 bg-linear-to-br from-[#f7941e] to-[#e08315] rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-[#f7941e]/30">
                <img src={service.icon.url} alt={service.icon.alt} width="32" height="32" class="w-8 h-8" />
              </div>
            )}

            <h3 class="text-2xl font-bold mb-3 text-white">{service.title}</h3>
            <p class="text-gray-400 mb-6 leading-relaxed">{service.description}</p>

            {service.features && service.features.length > 0 && (
              <div class="space-y-2 pt-4 border-t border-white/10">
                {service.features.map((feat) => (
                  <div class="flex items-center gap-3">
                    <div class="w-1.5 h-1.5 bg-[#f7941e] rounded-full"></div>
                    <span class="text-sm text-gray-500">{feat.feature_text}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>
